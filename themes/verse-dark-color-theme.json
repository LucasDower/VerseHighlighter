{
  "name": "Verse Dark",
  "type": "dark",
  "colors": {},
  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#6A9955", "fontStyle": "italic" }
    },
    {
      "name": "Strings",
      "scope": ["string"],
      "settings": { "foreground": "#CE9178" }
    },
    {
      "name": "String escape sequences",
      "scope": ["constant.character.escape"],
      "settings": { "foreground": "#D7BA7D" }
    },
    {
      "name": "String interpolation punctuation",
      "scope": ["punctuation.section.interpolation"],
      "settings": { "foreground": "#569CD6" }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#B5CEA8" }
    },
    {
      "name": "Boolean / language constants",
      "scope": ["constant.language"],
      "settings": { "foreground": "#569CD6" }
    },
    {
      "name": "Control flow keywords",
      "scope": ["keyword.control"],
      "settings": { "foreground": "#C586C0" }
    },
    {
      "name": "Other keywords (set, and, or, not, where)",
      "scope": ["keyword.other"],
      "settings": { "foreground": "#C586C0" }
    },
    {
      "name": "Storage types (struct, class, enum, interface, var)",
      "scope": ["storage.type"],
      "settings": { "foreground": "#569CD6" }
    },
    {
      "name": "Specifiers / access modifiers (<public>, <transacts>, …)",
      "scope": ["storage.modifier"],
      "settings": { "foreground": "#ce7878" }
    },
    {
      "name": "Built-in types (int, float, string, logic, …)",
      "scope": ["support.type.primitive"],
      "settings": { "foreground": "#4EC9B0" }
    },
    {
      "name": "Function names",
      "scope": ["entity.name.function"],
      "settings": { "foreground": "#DCDCAA" }
    },
    {
      "name": "Type names (struct/class/enum identifiers)",
      "scope": ["entity.name.type"],
      "settings": { "foreground": "#4EC9B0" }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#D4D4D4" }
    },
    {
      "name": "Path literals",
      "scope": ["string.unquoted.path"],
      "settings": { "foreground": "#CE9178", "fontStyle": "italic" }
    },
    {
      "name": "Variables",
      "scope": ["variable.other"],
      "settings": { "foreground": "#9CDCFE" }
    }
  ]
}
